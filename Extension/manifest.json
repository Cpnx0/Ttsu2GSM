{
  "manifest_version": 3,
  "name": "Ttsu2GSM",
  "version": "1.0",
  "description": "save important status to be transfered to GSM",
  "permissions": ["scripting","storage","unlimitedStorage","webNavigation","tabs"],
  "host_permissions": [
  "ws://localhost:9012/",
  "ws://127.0.0.1:9012/"
],
  "action": {
    "default_popup": "popup/settings.html"
  },
  "background":{
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "matches": [
        "https://reader.ttsu.app/*"
      ]
    }
  ]
}
