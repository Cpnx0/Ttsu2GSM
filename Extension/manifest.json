{
  "manifest_version": 3,
  "name": "Reader2GSM",
  "version": "1.0.2",
  "description": "Track and Store text lines in supported readers for GSM Stats",
  "permissions": ["storage","unlimitedStorage","activeTab", "webNavigation"],
  "host_permissions": ["http://localhost/*"],
  "action": {
    "default_popup": "popup/settings.html"
  },
  "options_ui": {
    "page": "popup/settings.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "background":{
    "service_worker": "background.js",
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "matches": [
        "https://reader.ttsu.app/*",
        "https://kamperemu.github.io/ebook-reader/*",
        "https://app.yatsu.moe/*",
        "http://localhost/*"
      ]
    }
  ],
  "browser_specific_settings": {
  "gecko": {
    "id": "CPNX-Support@github.io",
      "data_collection_permissions": {
        "required": [
          "websiteContent",
          "websiteActivity"
        ]
      }
    }
  }
}

